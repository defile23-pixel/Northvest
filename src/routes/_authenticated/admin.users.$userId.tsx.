import { createFileRoute, Link, useParams } from "@tanstack/react-router";
import { useQuery, useQueryClient } from "@tanstack/react-query";
import { useServerFn } from "@tanstack/react-start";
import { adminGetUserDetail, adminAdjustBalance, adminSetKycStatus, adminAddUserNote, adminSendMessage } from "@/lib/admin.functions";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import { Textarea } from "@/components/ui/textarea";
import { Badge } from "@/components/ui/badge";
import { ArrowLeft, ExternalLink } from "lucide-react";
import { useState } from "react";
import { toast } from "sonner";

export const Route = createFileRoute("/_authenticated/admin/users/$userId")({
  component: AdminUserDetail,
});

function explorerUrl(assetId: string | null, hash: string) {
  switch (assetId) {
    case "BTC": return `https://mempool.space/tx/${hash}`;
    case "ETH": return `https://etherscan.io/tx/${hash}`;
    case "USDT": return `https://tronscan.org/#/transaction/${hash}`;
    default: return null;
  }
}

const money = (n: number | null | undefined) => Number(n ?? 0).toLocaleString("en-US", { style: "currency", currency: "USD" });

function AdminUserDetail() {
  const { userId } = useParams({ from: "/_authenticated/admin/users/$userId" });
  const qc = useQueryClient();
  const getDetail = useServerFn(adminGetUserDetail);
  const adjust = useServerFn(adminAdjustBalance);
  const setKyc = useServerFn(adminSetKycStatus);
  const addNote = useServerFn(adminAddUserNote);
  const sendMessage = useServerFn(adminSendMessage);

  const q = useQuery({ queryKey: ["admin-user-detail", userId], queryFn: () => getDetail({ data: { userId } }) });

  const [cash, setCash] = useState("");
  const [invested, setInvested] = useState("");
  const [reason, setReason] = useState("");
  const [busy, setBusy] = useState(false);
  const [noteText, setNoteText] = useState("");
  const [noteBusy, setNoteBusy] = useState(false);
  const [msgTitle, setMsgTitle] = useState("");
  const [msgBody, setMsgBody] = useState("");
  const [msgBusy, setMsgBusy] = useState(false);

  const refresh = () => {
    qc.invalidateQueries({ queryKey: ["admin-user-detail", userId] });
    qc.invalidateQueries({ queryKey: ["admin-users"] });
  };

  const submitAdjust = async () => {
    if (!cash && !invested) return toast.error("Enter a new cash and/or invested amount");
    if (!reason.trim()) return toast.error("A reason is required — it's recorded in the audit log and shown to the user");
    setBusy(true);
    try {
      await adjust({ data: { userId, cash: cash !== "" ? Number(cash) : undefined, invested: invested !== "" ? Number(invested) : undefined, reason: reason.trim() } });
      toast.success("Balance updated, user notified");
      setCash(""); setInvested(""); setReason("");
      refresh();
    } catch (e: any) { toast.error(e.message); } finally { setBusy(false); }
  };

  const decideKyc = async (status: "approved" | "rejected" | "not_started") => {
    try { await setKyc({ data: { userId, status } }); toast.success("KYC status updated"); refresh(); }
    catch (e: any) { toast.error(e.message); }
  };

  const submitNote = async () => {
    if (!noteText.trim()) return toast.error("Note can't be empty");
    setNoteBusy(true);
    try { await addNote({ data: { userId, note: noteText.trim() } }); toast.success("Note added"); setNoteText(""); refresh(); }
    catch (e: any) { toast.error(e.message); } finally { setNoteBusy(false); }
  };

  const submitMessage = async () => {
    if (!msgTitle.trim() || !msgBody.trim()) return toast.error("Enter a title and a message");
    setMsgBusy(true);
    try { await sendMessage({ data: { userId, title: msgTitle.trim(), body: msgBody.trim() } }); toast.success("Message sent to user's notifications"); setMsgTitle(""); setMsgBody(""); refresh(); }
    catch (e: any) { toast.error(e.message); } finally { setMsgBusy(false); }
  };

  if (q.isLoading) return <div className="p-6 text-sm text-muted-foreground">Loading…</div>;
  if (q.error || !q.data) return <div className="p-6 text-sm text-destructive">Could not load this user.</div>;

  const { profile, email, wallet, kyc, roles, txns, events, notifications, notes } = q.data;

  return (
    <div className="space-y-6">
      <Button asChild variant="ghost" size="sm" className="-ml-2"><Link to="/admin/users"><ArrowLeft className="mr-1 h-4 w-4" /> Back to users</Link></Button>

      <div className="glass-card rounded-2xl p-5">
        <div className="flex flex-wrap items-start justify-between gap-3">
          <div>
            <p className="font-display text-xl font-bold">{profile.full_name || "Unnamed user"}</p>
            <p className="text-sm text-muted-foreground">{email ?? profile.id}</p>
            <p className="mt-1 text-[11px] text-muted-foreground">{profile.id}</p>
          </div>
          <div className="flex gap-2">
            {(roles ?? []).map((r: string) => <Badge key={r} variant="secondary" className="capitalize">{r}</Badge>)}
            <Badge variant={kyc?.status === "approved" ? "default" : "outline"} className="capitalize">KYC: {kyc?.status ?? "not_started"}</Badge>
          </div>
        </div>
      </div>

      <div className="grid gap-4 lg:grid-cols-2">
        <div className="glass-card rounded-2xl p-5">
          <p className="font-display text-lg font-bold">Wallet</p>
          <div className="mt-2 grid grid-cols-2 gap-3 text-sm">
            <div><p className="text-muted-foreground">Cash</p><p className="font-medium">{money(wallet?.cash_balance)}</p></div>
            <div><p className="text-muted-foreground">Invested</p><p className="font-medium">{money(wallet?.invested_balance)}</p></div>
          </div>
          <div className="mt-5 space-y-3 border-t border-border pt-4">
            <p className="text-sm font-medium">Adjust balance</p>
            <p className="text-xs text-muted-foreground">Leave a field blank to leave it unchanged. A reason is required — it's logged in the audit trail and shown to the user.</p>
            <div className="grid grid-cols-2 gap-3">
              <div><Label className="text-xs">New cash balance</Label><Input value={cash} onChange={(e) => setCash(e.target.value)} placeholder={String(wallet?.cash_balance ?? 0)} /></div>
              <div><Label className="text-xs">New invested balance</Label><Input value={invested} onChange={(e) => setInvested(e.target.value)} placeholder={String(wallet?.invested_balance ?? 0)} /></div>
            </div>
            <div><Label className="text-xs">Reason (required, visible to user)</Label><Textarea value={reason} onChange={(e) => setReason(e.target.value)} rows={2} placeholder="e.g. Correcting a duplicate deposit credit" /></div>
            <Button onClick={submitAdjust} disabled={busy} size="sm">Save adjustment</Button>
          </div>
        </div>

        <div className="glass-card rounded-2xl p-5">
          <p className="font-display text-lg font-bold">Identity verification</p>
          <p className="mt-1 text-sm text-muted-foreground">Status: <span className="font-medium capitalize">{kyc?.status ?? "not_started"}</span></p>
          {kyc?.document_path ? <p className="mt-1 text-xs text-muted-foreground">Document on file — review from the KYC tab to view it.</p> : <p className="mt-1 text-xs text-muted-foreground">No document uploaded yet.</p>}
          <div className="mt-4 flex flex-wrap gap-2">
            <Button size="sm" onClick={() => decideKyc("approved")}>Approve</Button>
            <Button size="sm" variant="outline" onClick={() => decideKyc("rejected")}>Reject</Button>
            <Button size="sm" variant="ghost" onClick={() => decideKyc("not_started")}>Reset</Button>
          </div>
          <p className="mt-6 font-display text-lg font-bold">Recent security events</p>
          <ul className="mt-2 max-h-48 space-y-2 overflow-y-auto text-sm">
            {(events ?? []).length === 0 && <li className="text-muted-foreground">No security events recorded.</li>}
            {events?.map((e: any) => (
              <li key={e.id} className="flex justify-between gap-2 text-xs">
                <span>{e.description ?? e.event_type}</span>
                <span className="shrink-0 text-muted-foreground">{new Date(e.created_at).toLocaleString()}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <div className="grid gap-4 lg:grid-cols-2">
        <div className="glass-card rounded-2xl p-5">
          <p className="font-display text-lg font-bold">Internal notes</p>
          <p className="mt-1 text-xs text-muted-foreground">Only visible to admins — not shown to the user.</p>
          <div className="mt-3 space-y-2">
            <Textarea value={noteText} onChange={(e) => setNoteText(e.target.value)} rows={2} placeholder="Add a note about this user…" />
            <Button size="sm" onClick={submitNote} disabled={noteBusy}>Add note</Button>
          </div>
          <ul className="mt-4 max-h-56 space-y-3 overflow-y-auto border-t border-border pt-4 text-sm">
            {(notes ?? []).length === 0 && <li className="text-muted-foreground">No notes yet.</li>}
            {notes?.map((n: any) => (
              <li key={n.id}>
                <p>{n.note}</p>
                <p
